# Yugoef — RuView + Qwen Cloud AI Agent
#
# Qwen Cloud API settings
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://portal.qwen.ai/v1
QWEN_MODEL=qwen3.7-plus
QWEN_MAX_TOKENS=1024
QWEN_TEMPERATURE=0.3

# RuView connection
RUVIEW_SIMULATED=true
# RUVIEW_MQTT_BROKER=localhost
# RUVIEW_MQTT_PORT=1883
# RUVIEW_API_URL=http://localhost:8080
# RUVIEW_WS_URL=ws://localhost:8765/ws/sensing

# Yugoef server
YUGOEF_HOST=0.0.0.0
YUGOEF_PORT=8000
YUGOEF_DEBUG=false
